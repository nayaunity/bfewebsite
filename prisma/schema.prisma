generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               String           @id @default(cuid())
  email            String           @unique
  emailVerified    DateTime?
  role             String           @default("user")
  firstName        String?
  lastName         String?
  phone            String?
  resumeUrl        String?
  resumeName       String?
  resumeUpdatedAt  DateTime?
  autoApplyEnabled  Boolean          @default(false)
  usState           String?
  workAuthorized    Boolean?
  needsSponsorship  Boolean?
  countryOfResidence  String?
  applicationEmail    String?          @unique
  linkedinUrl         String?
  githubUrl           String?
  websiteUrl          String?
  currentEmployer     String?
  currentTitle        String?
  school              String?
  degree              String?
  city                String?
  preferredName       String?
  yearsOfExperience   String?
  targetRole          String?
  pronouns            String?
  willingToRelocate   Boolean?
  remotePreference    String?
  earliestStartDate   String?
  graduationYear      String?
  additionalCerts     String?
  salaryExpectation   String?
  gender              String?
  race                String?
  hispanicOrLatino    String?
  veteranStatus       String?
  disabilityStatus    String?
  applicationAnswers  String?
  onboardingData      String?
  onboardingCompletedAt DateTime?
  stripeCustomerId    String?          @unique
  subscriptionTier    String           @default("free")
  subscriptionStatus  String           @default("inactive")
  stripeSubscriptionId String?         @unique
  currentPeriodEnd    DateTime?
  monthlyAppCount     Int              @default(0)
  monthlyAppResetAt   DateTime         @default(now())
  createdAt           DateTime         @default(now())
  accounts            Account[]
  progress            LessonProgress[]
  microWins           MicroWin[]
  sessions            Session[]
  createdJobs         Job[]
  jobApplications     JobApplication[]
  resumes             UserResume[]
  applyQueue          ApplyQueue[]
  browseSessions      BrowseSession[]
  tickets             Ticket[]

  @@index([role])
  @@index([stripeCustomerId])
  @@index([subscriptionTier])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model LessonProgress {
  id          String    @id @default(cuid())
  userId      String
  courseId    String
  lessonSlug  String
  completed   Boolean   @default(false)
  completedAt DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId, lessonSlug])
  @@index([userId])
  @@index([courseId])
}

model Job {
  id          String    @id @default(cuid())
  externalId  String
  company     String
  companySlug String
  title       String
  location    String
  type        String
  remote      Boolean   @default(false)
  salary      String?
  postedAt    DateTime?
  applyUrl    String
  category    String
  tags        String
  source      String
  isActive    Boolean   @default(true)
  scrapedAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdById String?
  createdBy   User?     @relation(fields: [createdById], references: [id])

  applications    JobApplication[]
  applyQueue      ApplyQueue[]

  @@unique([externalId, companySlug])
  @@index([category])
  @@index([remote])
  @@index([isActive])
  @@index([companySlug])
  @@index([createdById])
}

model JobApplication {
  id            String    @id @default(cuid())
  userId        String
  jobId         String
  externalJobId String
  company       String
  companySlug   String
  boardToken    String
  jobTitle      String
  status        String    @default("pending")
  errorMessage  String?
  submittedAt   DateTime?
  createdAt     DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id])

  @@unique([userId, jobId])
  @@index([userId])
  @@index([jobId])
  @@index([status])
  @@index([companySlug])
  @@index([createdAt])
}

model AutoApplyRun {
  id           String    @id @default(cuid())
  userId       String
  status       String    @default("running")
  totalJobs    Int       @default(0)
  submitted    Int       @default(0)
  skipped      Int       @default(0)
  failed       Int       @default(0)
  errorMessage String?
  startedAt    DateTime  @default(now())
  completedAt  DateTime?

  @@index([userId])
  @@index([startedAt])
}

model UserResume {
  id         String   @id @default(cuid())
  userId     String
  name       String
  fileName   String
  blobUrl    String
  keywords   String   @default("[]")
  isFallback Boolean  @default(false)
  uploadedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ApplyQueue {
  id            String    @id @default(cuid())
  userId        String
  jobId         String
  status        String    @default("queued")
  priority      Int       @default(0)
  resumeUrl     String
  resumeName    String
  applicantData String
  workerNote    String?
  errorMessage  String?
  createdAt     DateTime  @default(now())
  startedAt     DateTime?
  completedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id])

  @@unique([userId, jobId])
  @@index([status])
  @@index([createdAt])
  @@index([userId])
}

model BrowseSession {
  id             String    @id @default(cuid())
  userId         String
  targetRole     String
  companies      String
  resumeUrl      String
  resumeName     String
  status         String    @default("queued")
  totalCompanies Int       @default(0)
  companiesDone  Int       @default(0)
  jobsFound      Int       @default(0)
  jobsApplied    Int       @default(0)
  jobsSkipped    Int       @default(0)
  jobsFailed     Int       @default(0)
  progressLog    String    @default("[]")
  errorMessage   String?
  createdAt      DateTime  @default(now())
  startedAt      DateTime?
  completedAt    DateTime?

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  discoveries BrowseDiscovery[]

  @@index([status])
  @@index([userId])
  @@index([createdAt])
}

model BrowseDiscovery {
  id           String   @id @default(cuid())
  sessionId    String
  company      String
  jobTitle     String
  applyUrl     String
  status       String   @default("found")
  errorMessage String?
  createdAt    DateTime @default(now())

  session BrowseSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, applyUrl])
  @@index([sessionId])
  @@index([status])
}

model ScrapeLog {
  id           String   @id @default(cuid())
  companySlug  String
  status       String
  jobsFound    Int      @default(0)
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([companySlug])
  @@index([createdAt])
}

model ErrorLog {
  id        String   @id @default(cuid())
  userId    String?
  endpoint  String
  method    String   @default("UNKNOWN")
  status    Int      @default(500)
  error     String
  detail    String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([endpoint])
  @@index([createdAt])
  @@index([status])
}

model JobClick {
  id          String   @id @default(cuid())
  jobId       String
  company     String
  companySlug String
  jobTitle    String
  applyUrl    String
  clickedAt   DateTime @default(now())

  @@index([companySlug])
  @@index([clickedAt])
  @@index([jobId])
}

model MicroWin {
  id         String   @id @default(cuid())
  content    String
  promptType String
  authorName String?
  authorId   String?
  status     String   @default("approved")
  createdAt  DateTime @default(now())
  author     User?    @relation(fields: [authorId], references: [id])

  @@index([status])
  @@index([promptType])
  @@index([createdAt])
}

model Activity {
  id        String   @id @default(cuid())
  type      String
  message   String
  metadata  String?
  createdAt DateTime @default(now())

  @@index([type])
  @@index([createdAt])
}

model PagePresence {
  id         String   @id @default(cuid())
  visitorId  String
  page       String
  country    String?
  lastSeenAt DateTime @default(now())

  @@unique([visitorId, page])
  @@index([page])
  @@index([lastSeenAt])
  @@index([country])
}

model Link {
  id          String   @id @default(cuid())
  title       String
  description String?
  url         String
  category    String?
  featured    Boolean  @default(false)
  image       String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([featured])
  @@index([order])
  @@index([isActive])
}

model LinkClick {
  id        String   @id @default(cuid())
  linkId    String
  linkTitle String
  linkUrl   String
  clickedAt DateTime @default(now())

  @@index([linkId])
  @@index([clickedAt])
}

model BlogView {
  id        String   @id @default(cuid())
  slug      String
  title     String
  viewedAt  DateTime @default(now())

  @@index([slug])
  @@index([viewedAt])
}

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String
  content     String
  author      String   @default("Nyaradzo")
  category    String   @default("Career")
  tags        String   @default("[]")
  featured    Boolean  @default(false)
  image       String?
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([featured])
  @@index([category])
  @@index([publishedAt])
}

model InboundEmail {
  id         String   @id @default(cuid())
  toEmail    String
  fromEmail  String
  fromName   String?
  subject    String
  textBody   String?
  htmlBody   String?
  receivedAt DateTime @default(now())
  processed  Boolean  @default(false)

  @@index([toEmail, receivedAt])
}

model Ticket {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("bug") // bug, feature, question
  status    String   @default("new") // new, in-progress, done
  page      String?  // which page the ticket was submitted from
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

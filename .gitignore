# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma
prisma/dev.db
prisma/dev.db-journal
.env*.local

# job assets - personal data (resumes, answers, etc.)
job-assets/resumes/*.pdf
job-assets/application-answers.json
*.resume.pdf
NBere_Resume.pdf

# user-data exports (never commit PII dumps; see security audit)
/*.csv

# playwright-mcp automation artifacts (may contain session state)
.playwright-mcp/

# root-level sqlite (prisma/dev.db is the real one; this catches stray copies)
/dev.db
/dev.db-journal

# worker dependencies (worker has its own package.json; the root /node_modules
# rule above doesn't catch this nested copy).
/worker/node_modules

# Workday recon + smoke debug artifacts (large PNGs / per-run JSON dumps that
# pile up while iterating on a tenant). The recon `.ts` source files ARE
# tracked. Only the rendered outputs are excluded.
/worker/test/integration/recon-*.png
/worker/test/integration/recon-*.json
/worker/test/integration/smoke-results-*.json
/worker/test/integration/wd-debug-*.png
